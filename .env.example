# Klaviyo — public-only keys, safe to ship to the browser.
# Get these from your Klaviyo dashboard.
#
#   PUBLIC_KLAVIYO_COMPANY_ID  Account → Settings → API Keys → Public API Key
#                              (6-character string, e.g. "AbCdEf")
#   PUBLIC_KLAVIYO_LIST_ID     Lists & Segments → "MPower Waitlist" → copy ID
#                              from the URL (6-character string)
#
# Both are exposed to client-side JS — that's intentional and per Klaviyo's
# Client API docs. The Public API Key can only create profiles / subscribe
# to lists; it cannot read your data.

PUBLIC_KLAVIYO_COMPANY_ID=REPLACE_ME
PUBLIC_KLAVIYO_LIST_ID=REPLACE_ME
