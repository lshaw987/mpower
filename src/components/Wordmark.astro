---
/**
 * MPower parent wordmark. The "M" is Spring green (bold Accent); "Power" is
 * regular, Mist on dark / inherits. The optional tagline lockup adds
 * "Knowledge. Power. Yours." underneath.
 * Vertical lockups (M + Power + italic vertical name in the Ink colour) are
 * rendered by VerticalCard.astro, not here.
 * (Equip2MPower / the italic-2 device is revived by the 18 May 2026 spec as
 * the tagline device; the brand name stays plain MPower.)
 *
 * Props:
 *   size: 'sm' | 'md' | 'lg'  (controls font-size, wraps in clamp)
 *   tagline: boolean          (show the tagline line beneath)
 */
interface Props {
  size?: 'sm' | 'md' | 'lg';
  tagline?: boolean;
  href?: string | null;
}
const { size = 'md', tagline = false, href = '/' } = Astro.props;
const sizeClass = `wm wm-${size}`;
---
{href ? (
  <a href={href} class={sizeClass} aria-label="MPower - home">
    <span class="wm-mark"><span class="wm-m">M</span>Power</span>
    {tagline && (
      <span class="wm-tag">Knowledge. Power. Yours.</span>
    )}
  </a>
) : (
  <span class={sizeClass}>
    <span class="wm-mark"><span class="wm-m">M</span>Power</span>
    {tagline && (
      <span class="wm-tag">Knowledge. Power. Yours.</span>
    )}
  </span>
)}

<style>
  .wm { display: inline-flex; flex-direction: column; gap: 2px; line-height: 1; color: inherit; }
  .wm-mark {
    font-family: var(--f-display);
    font-weight: 800;
    letter-spacing: -0.03em;
  }
  .wm-m { color: var(--c-spring); }
  .wm-sm .wm-mark { font-size: 22px; }
  .wm-md .wm-mark { font-size: 28px; }
  .wm-lg .wm-mark { font-size: clamp(48px, 6vw, 88px); }

  .wm-tag {
    font-family: var(--f-display);
    font-weight: 500;
    letter-spacing: 0;
    color: var(--c-fog);
    font-size: 12px;
    margin-top: 4px;
  }
  .wm-lg .wm-tag { font-size: clamp(16px, 1.5vw, 22px); margin-top: 8px; }
  .wm-2 { font-style: italic; color: var(--c-spring); font-weight: 800; }
</style>
