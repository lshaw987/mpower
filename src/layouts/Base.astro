---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  current?: string;
  ogImage?: string;
}
const {
  title,
  description = 'MPower — knowledge, power, yours. Built so people get answers in their own language, on their own phone, in the moment they need them. Pre-launch 2026.',
  current,
  ogImage = '/og-default.png',
} = Astro.props;
const fullTitle = title === 'MPower' ? title : `${title} · MPower`;
---
<!doctype html>
<html lang="en-NZ">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0B1620" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    {/* Open Graph + Twitter */}
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta name="twitter:card" content="summary_large_image" />

    {/* Favicon — placeholder; replace with real assets at build time */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Preconnect to Google Fonts — small win, real on slow connections */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Nav current={current} />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <style>
      .skip-link {
        position: absolute; top: -100px; left: 16px;
        background: var(--c-spring); color: var(--c-spring-ink);
        padding: 10px 14px; border-radius: 8px; font-weight: 600;
        z-index: 100;
      }
      .skip-link:focus { top: 16px; }
    </style>
  </body>
</html>
