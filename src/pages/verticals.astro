---
import Base from '../layouts/Base.astro';
import VerticalCard from '../components/VerticalCard.astro';
---
<Base title="Verticals" current="Verticals" description="The MPower family. Same wordmark, same typography, same Deep Sea base. Each vertical claims one signature accent.">

  <section class="section">
    <div class="container">
      <div class="mono kicker">§ The family · Phase 1</div>
      <h1 class="display verts-h1">
        Siblings, <span class="i-accent">not clones.</span>
      </h1>
      <p class="body-lg verts-lede">
        Same wordmark. Same typography. Same Deep Sea base. Each vertical claims one signature accent rooted in something deep about its meaning. <span class="accent">Discipline is the system. Flexibility is the flavour.</span>
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <hr class="rule" style="margin-bottom: 48px;" />

      <div id="agri" class="vert-feature">
        <VerticalCard
          name="Agri"
          tagline="For people who work with soil and seasons."
          body="The colour of fired earth, of pots that hold seed, of soil at sunset. Universal across cultures — clay pots, brick, earthen homes — carrying thousands of years of meaning around food, harvest, and human craft. The radical move: skip green entirely. Every other ag brand defaults there. We claim the colour of the ground itself."
          url="https://agri.mpowerhq.co.nz"
          accent="var(--c-clay)"
          ink="var(--c-wheat)"
          tags={[['Clay','#C04B26'],['Earth','#8B2F15'],['Wheat','#FFD9A8'],['Soil','#2D1810']]}
        />
      </div>

      <div id="ed" class="vert-feature">
        <VerticalCard
          name="Ed"
          tagline="For everyone who learns. For everyone who teaches."
          body="The colour humans have used to write knowledge for over 4,000 years — from cuneiform to fountain pen to printed page. Gold is the spark of insight, the moment of understanding. The radical move: skip the lazy edtech blue that every learning startup uses. We claim the deeper, older blue — the one ideas have always been written in."
          url="https://ed.mpowerhq.co.nz"
          accent="var(--c-indigo)"
          ink="var(--c-page)"
          tags={[['Indigo','#4338CA'],['Night','#1E1B4B'],['Gold','#FCD34D'],['Page','#E0E7FF']]}
        />
      </div>

      <hr class="rule" style="margin-block: 48px;" />

      <div class="future-head">
        <span class="mono">§ 03 · Future · To be earned</span>
        <h2 class="display future-title">
          Each new vertical earns its colour through the same logic.
        </h2>
      </div>

      <div class="future-grid">
        <VerticalCard name="Health"  tagline="Life and care." body="Cardinal red — the colour of life, the universal sign of care, used across every culture for medical and spiritual healing." accent="#B91C1C" coming={true} />
        <VerticalCard name="Finance" tagline="Trust and value." body="Obsidian black and gold leaf — the colour of trust, of precious things; skips both bank-blue and money-green." accent="#0A0A0A" coming={true} />
        <VerticalCard name="Civic"   tagline="Authority and judgement." body="Deep purple — the colour of authority and judgement, while skipping political-party associations." accent="#5B21B6" coming={true} />
      </div>
    </div>
  </section>

</Base>

<style>
  .kicker { color: var(--c-spring); margin-bottom: 36px; }
  .verts-h1 { font-size: var(--t-h1); max-width: 14ch; }
  .verts-lede { margin-top: 32px; max-width: 64ch; opacity: .9; }
  .vert-feature { margin-bottom: 32px; }
  .future-head { margin-bottom: 32px; }
  .future-head .mono { color: var(--c-fog); display: block; margin-bottom: 18px; }
  .future-title { font-size: var(--t-h3); max-width: 24ch; }
  .future-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  @media (max-width: 860px) { .future-grid { grid-template-columns: 1fr; } }
</style>
