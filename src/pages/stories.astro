---
import Base from '../layouts/Base.astro';
import GreenBlock from '../components/GreenBlock.astro';
---
<Base title="Stories" current="Stories" description="Real member stories land here after launch. No saviour-narrative imagery, no stock boardrooms, no pity-bait. Hands, not headshots.">

  <section class="section">
    <div class="container">
      <div class="mono kicker">§ Stories · Fig. 03 - Hands, not headshots · Aotearoa</div>
      <h1 class="display stories-h1">
        Real people. <span class="i-accent">After launch.</span>
      </h1>
      <p class="body-lg stories-lede">
        We're pre-launch, so there are no stories here yet - and we won't invent any. When real members tell us what changed, in their words and with their permission, their stories land here. Real people, real moments. No saviour-narrative imagery, no stock boardrooms, no pity-bait close-ups. Hands, not headshots.
      </p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <hr class="rule" style="margin-bottom: 48px;" />
      <div class="holding">
        <span class="mono accent">§ Until then</span>
        <p class="body-lg holding-body">
          If you want to be one of the first - and you'd be open to telling us what changed once you're in - join the waitlist. Founding members shape what this community becomes.
        </p>
        <a href="/waitlist" class="btn btn-primary" style="margin-top: 32px;">Join the waitlist <span class="arr">→</span></a>
      </div>
    </div>
  </section>

  <GreenBlock kicker="§ The promise">
    <h2>We don't fake it. <em>Real stories, or none.</em></h2>
  </GreenBlock>

</Base>

<style>
  .kicker { color: var(--c-spring); margin-bottom: 36px; }
  .stories-h1 { font-size: var(--t-h1); max-width: 14ch; }
  .stories-lede { margin-top: 32px; max-width: 64ch; opacity: .9; }

  .holding { max-width: 60ch; }
  .holding-body { margin-top: 18px; opacity: .9; }

  @media (max-width: 860px) {
    .holding { max-width: none; }
  }
</style>
