---
import Base from '../layouts/Base.astro';
import GreenBlock from '../components/GreenBlock.astro';
import VerticalCard from '../components/VerticalCard.astro';
---
<Base title="MPower" current="Home" description="MPower - a subscription community that equips people with the knowledge, power and skills to grow, thrive and flourish, without relying on anyone else for the answers. Pre-launch in Aotearoa NZ, 2026.">

  {/* Hero ─────────────────────────────────────────────────────────────── */}
  <section class="hero">
    <div class="container">
      <div class="mono hero-kicker">§ Pre-launch · 2026</div>
      <h1 class="display hero-title">
        Knowledge. <span class="i-accent">Power.</span> Yours.
      </h1>
      <p class="body-lg hero-sub">
        MPower is the answer you came for... in your language, on your phone, in the moment you need it. We're built so people don't need us - but stay because you love being part of our community and keep growing, thriving and flourishing. <span class="accent">Equip you. Then empower you.</span>
      </p>
      <div class="hero-ctas">
        <a href="/waitlist" class="btn btn-primary">Join the waitlist <span class="arr">→</span></a>
        <a href="/about" class="btn btn-ghost">The why <span class="arr">→</span></a>
      </div>

      <hr class="rule" style="margin-top: 72px;" />
      <div class="hero-footnote">
        <span class="mono">§ Fig. 01 - The name encodes the journey.</span>
        <span class="mono">Equip<span class="i-accent">2</span>MPower</span>
      </div>
    </div>
  </section>

  {/* Manifesto ──────────────────────────────────────────────────────────── */}
  <section class="manifesto">
    <div class="container">
      <div class="mf-kicker mono">§ The why</div>
      <h2 class="mf-statement display">
        People are <span class="i-accent">already capable.</span>
      </h2>
      <div class="mf-body">
        <aside class="mf-side">
          <span class="mono">§ The why</span>
          <p class="mf-aside body-sm">The world doesn't lack for expertise. It lacks people wanting to build each other up.</p>
        </aside>
        <div class="mf-prose">
          <p class="body-lg mf-lede">
            They just need the right tools, in the right place, in plain language. Good knowledge sits behind paywalls, buried in jargon, locked in industry bodies too slow or too gatekept to get it to the people doing the work.
          </p>
          <p class="body mf-graf">
            That's a delivery failure, not a capability gap. MPowered is what people become, not what we do <em>to</em> them. The italic <span class="i-accent">2</span> in our tagline is the bridge between knowing and doing. We equip - the knowledge, the tools, the plain-language how - and the power is yours from there.
          </p>
          <p class="body mf-graf">
            No gatekeepers. No jargon. No sense that someone's talking down to you. We're on a mission to change that.
          </p>
        </div>
      </div>
      <hr class="rule mf-rule" />
      <p class="mf-pull display">
        Success looks like the day you <span class="i-accent">don't need us</span> anymore... and you stay anyway, because you love the community, and keep <span class="i-accent">growing, thriving, flourishing.</span>
      </p>
    </div>
  </section>

  {/* Phase 1 verticals ─────────────────────────────────────────────────── */}
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="mono">§ 02 · Our communities · Phase 1</span>
        <h2 class="display" style="font-size: var(--t-h2); max-width: 18ch;">
          One open now. <span class="i-accent">Two launching next.</span>
        </h2>
      </div>

      <div style="margin-bottom: 24px;">
        <VerticalCard
          name="Teams"
          badge="Available now · MPower Teams"
          tagline="Your team. Your context."
          body="Leadership development built around your team, your context and your growth trajectory - ongoing, not a one-workshop wonder. Open now, by arrangement."
          url="mailto:askme@mpowerhq.nz?subject=MPower Teams enquiry"
          host="askme@mpowerhq.nz"
          accent="var(--c-bronze)"
          ink="var(--c-amber)"
        />
      </div>

      <div class="vert-grid">
        <VerticalCard
          name="Agri"
          badge="01 · MPower Agri"
          tagline="Leadership for people who work with soil and seasons."
          body="For the people carrying the business side of a food and fibre operation - the budgets, the team, the succession plan, the hard calls. You can find an agronomist, a vet, a stock agent. This is the one place built for the leadership and the business behind the farm gate, in plain language, with nobody selling you anything."
          url="https://agri.mpowerhq.nz"
          host="agri.mpowerhq.nz"
          accent="var(--c-clay)"
          ink="var(--c-wheat)"
          tags={[['Clay','#C04B26'],['Wheat','#FFD9A8'],['Earth','#8B2F15'],['Soil','#2D1810']]}
        />
        <VerticalCard
          name="Ed"
          badge="02 · MPower Ed"
          tagline="Leadership for everyone who learns. For everyone who teaches."
          body="Yours is the one trade whose whole job is to pass it on - and the people leading it get the least support for the leadership side. Built for principals, board chairs, department heads, training leads, kura and ECE management. The tools, the language, and a community leading the same load, so you're not carrying it on your own."
          url="https://ed.mpowerhq.nz"
          host="ed.mpowerhq.nz"
          accent="var(--c-indigo)"
          ink="var(--c-gold)"
          tags={[['Indigo','#818CF8'],['Gold','#FCD34D'],['Night','#1E1B4B'],['Page','#E0E7FF']]}
        />
      </div>

      <div class="vert-future">
        <div class="mono">§ 02 · The leadership ladder - coming soon</div>
        <div class="vert-grid">
          <VerticalCard
            name="Leaders"
            tagline="Coaching and community."
            body="For individuals who want the benefit of coaching and a community that has their back - a place to grow alongside others on the same path."
            accent="var(--c-violet)"
            ink="var(--c-lilac)"
            coming={true}
          />
          <VerticalCard
            name="Rising"
            tagline="Headstart and habits."
            body="Our next generation of leaders - giving them a headstart in the world, with the language and habits of leadership before they need them."
            accent="var(--c-cyan)"
            ink="var(--c-mint)"
            coming={true}
          />
        </div>
      </div>
    </div>
  </section>

  {/* Green statement ───────────────────────────────────────────────────── */}
  <GreenBlock
    kicker="§ Built so you don't need us anymore."
    cta={{ href: '/about', label: 'Read the why' }}
  >
    <h2>Built so you <em>don't need us</em> anymore.</h2>
    <p>
      People are already capable. They just need the right tools, in the right place, in plain language. The world doesn't lack for expertise - it lacks people genuinely wanting to build each other up.
    </p>
  </GreenBlock>

  {/* How it works ──────────────────────────────────────────────────────── */}
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="mono">§ How it works</span>
        <h2 class="display" style="font-size: var(--t-h2); max-width: 22ch;">
          One place. <span class="i-accent">Nobody selling you anything.</span>
        </h2>
      </div>

      <ol class="steps">
        <li>
          <span class="step-num">01</span>
          <h3 class="heading step-title">Free, on social.</h3>
          <p class="body step-body">The genuinely useful stuff lives in public. No teasers, no gate. That's the access promise, made real.</p>
        </li>
        <li>
          <span class="step-num">02</span>
          <h3 class="heading step-title">Try the community free for 30 days.</h3>
          <p class="body step-body">Card captured at signup so there's no break - never charged during the trial, cancel in one click anytime.</p>
        </li>
        <li>
          <span class="step-num">03</span>
          <h3 class="heading step-title">Stay for the room and the library.</h3>
          <p class="body step-body">A real community plus a plain-language resource library. First 100 founding members lock their rate for life.</p>
        </li>
      </ol>

      <a href="/how-it-works" class="btn btn-ghost" style="margin-top: 56px;">
        How it works, in full <span class="arr">→</span>
      </a>
    </div>
  </section>

</Base>

<style>
  /* Hero -------------------------------------------------------------- */
  .hero { padding-block: clamp(80px, 12vw, 180px); }
  .hero-kicker { color: var(--c-spring); margin-bottom: 32px; }
  .hero-title {
    font-size: var(--t-display);
    max-width: 14ch;
    line-height: 0.92;
  }
  .hero-sub {
    margin-top: clamp(28px, 3vw, 44px);
    max-width: 60ch;
    font-size: var(--t-body-lg);
    opacity: .9;
  }
  .hero-ctas {
    display: flex; gap: 14px; flex-wrap: wrap;
    margin-top: clamp(36px, 4vw, 56px);
  }
  .hero-footnote {
    display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap;
    padding-top: 18px;
  }
  .hero-footnote .mono:first-child { color: var(--c-spring); }

  /* Manifesto --------------------------------------------------------- */
  .manifesto { padding-block: clamp(80px, 10vw, 140px); border-top: 1px solid var(--c-rule); }
  .mf-kicker { color: var(--c-spring); margin-bottom: 32px; letter-spacing: 0.18em; }
  .mf-statement {
    font-size: clamp(56px, 7vw, 104px);
    line-height: 1.0;
    letter-spacing: -0.035em;
    max-width: 22ch;
    padding-bottom: 0.1em;
  }
  .mf-body {
    display: grid;
    grid-template-columns: 1fr 2.4fr;
    gap: clamp(40px, 6vw, 96px);
    margin-top: clamp(48px, 6vw, 80px);
  }
  .mf-side .mono { color: var(--c-spring); display: block; margin-bottom: 14px; }
  .mf-aside { font-style: italic; opacity: .85; max-width: 28ch; }
  .mf-prose { max-width: 62ch; }
  .mf-lede { font-size: clamp(20px, 1.8vw, 26px); line-height: 1.5; opacity: .92; }
  .mf-graf { margin-top: 24px; opacity: .85; }
  .mf-rule { margin-top: clamp(56px, 6vw, 88px); }
  .mf-pull {
    font-size: clamp(40px, 5vw, 72px);
    line-height: 1.04;
    letter-spacing: -0.035em;
    max-width: 24ch;
    margin-top: clamp(36px, 4vw, 56px);
    padding-bottom: 0.1em;
  }
  @media (max-width: 860px) {
    .mf-body { grid-template-columns: 1fr; }
  }

  /* Verticals --------------------------------------------------------- */
  .vert-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .vert-future { margin-top: clamp(64px, 7vw, 96px); }
  .vert-future > .mono { color: var(--c-fog); margin-bottom: 24px; display: block; }
  .vert-grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  @media (max-width: 860px) {
    .vert-grid { grid-template-columns: 1fr; }
    .vert-grid-3 { grid-template-columns: 1fr; }
  }

  /* Steps ------------------------------------------------------------- */
  .steps {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }
  .steps li {
    padding: 32px 28px 32px 0;
    border-top: 1px solid var(--c-rule);
    display: flex; flex-direction: column; gap: 14px;
  }
  .step-num {
    font-family: var(--f-display);
    font-weight: 800;
    color: var(--c-spring);
    font-size: clamp(36px, 4vw, 56px);
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .step-title { font-size: var(--t-h4); }
  .step-body  { max-width: 36ch; opacity: .85; }

  @media (max-width: 860px) {
    .steps { grid-template-columns: 1fr; }
  }
</style>
