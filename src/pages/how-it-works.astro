---
import Base from '../layouts/Base.astro';
import GreenBlock from '../components/GreenBlock.astro';
---
<Base title="How it works" current="How it works" description="Free on social. Try the community free for 30 days. Stay for the room and the library. Nobody selling you anything inside.">

  <section class="section">
    <div class="container">
      <div class="mono kicker">§ How it works</div>
      <h1 class="display hiw-h1">
        One place. <span class="i-accent">Nobody selling you anything.</span>
      </h1>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <figure class="media">
        <div class="media-frame"><img src="/images/how-it-works.jpg" alt="In the moment you need it." loading="lazy" /></div>
        <figcaption class="mono">§ Fig. 04 · In the moment you need it · Kitchen table, ute, staffroom</figcaption>
      </figure>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      {[
        {n:'§ 01', t:'Free, on social.', b:'The genuinely useful stuff lives in public - no teasers, no gate. That is the access promise made real. Nobody is locked out of the knowledge that lives in the open.'},
        {n:'§ 02', t:'Try the community free for 30 days.', b:'We capture your card at signup so there is no break and no surprise. We do not charge it during the trial. Cancel in one click, anytime, including during the trial.'},
        {n:'§ 03', t:'Stay for the room and the library.', b:'A real community in Circle plus a plain-language resource library in Notion - tools, templates, summaries. The first 100 founding members lock their rate for life.'},
      ].map((s) => (
        <article class="step">
          <div>
            <span class="mono accent">{s.n}</span>
            <h3 class="display step-title">{s.t}</h3>
          </div>
          <p class="body-lg step-body">{s.b}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <hr class="rule" style="margin-bottom: 48px;" />
      <span class="mono accent">§ The principles</span>
      <h2 class="display principles-title">
        Plain language. <span class="i-accent">No gatekeepers.</span>
      </h2>

      <div class="principles">
        {[
          ['Plain, not simple',  'Everyday language, never dumbed down. Strip the jargon, keep the intelligence. Written the way you would say it, with NZ examples and how things really work here.'],
          ['Nobody selling you', 'No ads, no sponsors, no affiliate deals inside the communities, including us upselling you. That is a promise to members, and it is not negotiable.'],
          ['One place',          'The single source of truth people say does not exist - the community and the library together, not scattered across forty tabs and forty-page PDFs.'],
          ['Built so you do not need us', 'We measure success by the day you can answer for yourself, teach someone else, and pass it on - and stay anyway, because you love the community.'],
        ].map(([t, b]) => (
          <div class="principle">
            <h4 class="heading principle-title">{t}</h4>
            <p class="body principle-body">{b}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <GreenBlock cta={{ href: '/waitlist', label: 'Join the waitlist' }}>
    <h2>If this sounds like something you needed years ago - <em>we'd like to hear from you.</em></h2>
  </GreenBlock>

</Base>

<style>
  .kicker { color: var(--c-spring); margin-bottom: 36px; }
  .hiw-h1 { font-size: var(--t-h1); max-width: 18ch; }
  .media { margin: 0; }
  .media-frame { border-radius: 4px; overflow: hidden; border: 1px solid var(--c-rule-soft); }
  .media-frame img { display: block; width: 100%; height: auto; aspect-ratio: 16 / 9; object-fit: cover; filter: saturate(.92) brightness(.97); }
  .media figcaption { font-family: var(--f-mono); font-size: var(--t-mono); letter-spacing: .1em; text-transform: uppercase; color: var(--c-fog); padding-top: 12px; }

  .step {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 96px;
    padding-block: 56px;
    border-top: 1px solid var(--c-rule);
  }
  .step:last-child { border-bottom: 1px solid var(--c-rule); }
  .step-title { font-size: var(--t-h3); margin-top: 18px; max-width: 14ch; }
  .step-body  { max-width: 52ch; }

  .principles-title { font-size: var(--t-h2); margin-top: 24px; max-width: 22ch; }
  .principles {
    margin-top: 56px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 36px 48px;
  }
  .principle { border-top: 1px solid var(--c-rule); padding-top: 20px; }
  .principle-title { font-size: var(--t-h4); }
  .principle-body  { margin-top: 12px; max-width: 44ch; opacity: .85; }

  @media (max-width: 860px) {
    .step { grid-template-columns: 1fr; gap: 24px; }
    .principles { grid-template-columns: 1fr; }
  }
</style>
