---
import Base from '../layouts/Base.astro';
import GreenBlock from '../components/GreenBlock.astro';
---
<Base title="How it works" current="How it works" description="Free on social. Try the community free for 30 days. Stay for the room and the library. Nobody selling you anything inside.">

  <section class="section">
    <div class="container">
      <div class="mono kicker">§ How it works</div>
      <h1 class="display hiw-h1">
        Real answers. <span class="i-accent">No jargon. No gatekeepers.</span>
      </h1>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <figure class="media">
        <div class="media-frame"><img src="/images/how-it-works.jpg" alt="In the moment you need it." loading="lazy" /></div>
        <figcaption class="mono">§ Fig. 04 · In the moment you need it · Kitchen table, ute, staffroom</figcaption>
      </figure>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      {[
        {n:'§ 01', t:'Find us free on social.', b:'The genuinely useful stuff lives out in the open - no paywall, no sign-up, nobody locked out. That is the front door, and it stays open.'},
        {n:'§ 02', t:'Come inside when you\'re ready.', b:'Join your community on a 30-day trial. The full resource library in plain language, the events, and the people doing exactly what you\'re doing.'},
        {n:'§ 03', t:'Grow until you don\'t need us.', b:'Use it, make it yours, pass it on. We measure success by the day you can answer for yourself - and you stay anyway, because you love the community.'},
      ].map((s) => (
        <article class="step">
          <div>
            <span class="mono accent">{s.n}</span>
            <h3 class="display step-title">{s.t}</h3>
          </div>
          <p class="body-lg step-body">{s.b}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <hr class="rule" style="margin-bottom: 48px;" />
      <span class="mono accent">§ 04 · How we build it</span>
      <h2 class="display principles-title">
        Plain language. <span class="i-accent">Nobody selling you anything.</span>
      </h2>

      <div class="principles">
        {[
          ['Plain, not simple',  'Strip the jargon, keep the intelligence. No buzzwords, no one talking down to you.'],
          ['Async and self-paced', 'Recorded, downloadable, on your time. Watch it at 5am or 11pm - your call, your rhythm.'],
          ['Ask without the cringe', 'An anonymous-question option, because nobody should feel like an idiot for not knowing.'],
          ['Nobody selling you anything', 'No upsell, no affiliate links, no sponsor in your ear. Just the answer you came for.'],
        ].map(([t, b]) => (
          <div class="principle">
            <h4 class="heading principle-title">{t}</h4>
            <p class="body principle-body">{b}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <GreenBlock cta={{ href: '/waitlist', label: 'Join the waitlist' }}>
    <h2>If this sounds like something you needed years ago - <em>we'd like to hear from you.</em></h2>
  </GreenBlock>

</Base>

<style>
  .kicker { color: var(--c-spring); margin-bottom: 36px; }
  .hiw-h1 { font-size: var(--t-h1); max-width: 18ch; }
  .media { margin: 0; }
  .media-frame { border-radius: 4px; overflow: hidden; border: 1px solid var(--c-rule-soft); }
  .media-frame img { display: block; width: 100%; height: auto; aspect-ratio: 16 / 9; object-fit: cover; filter: saturate(.92) brightness(.97); }
  .media figcaption { font-family: var(--f-mono); font-size: var(--t-mono); letter-spacing: .1em; text-transform: uppercase; color: var(--c-fog); padding-top: 12px; }

  .step {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 96px;
    padding-block: 56px;
    border-top: 1px solid var(--c-rule);
  }
  .step:last-child { border-bottom: 1px solid var(--c-rule); }
  .step-title { font-size: var(--t-h3); margin-top: 18px; max-width: 14ch; }
  .step-body  { max-width: 52ch; }

  .principles-title { font-size: var(--t-h2); margin-top: 24px; max-width: 22ch; }
  .principles {
    margin-top: 56px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 36px 48px;
  }
  .principle { border-top: 1px solid var(--c-rule); padding-top: 20px; }
  .principle-title { font-size: var(--t-h4); }
  .principle-body  { margin-top: 12px; max-width: 44ch; opacity: .85; }

  @media (max-width: 860px) {
    .step { grid-template-columns: 1fr; gap: 24px; }
    .principles { grid-template-columns: 1fr; }
  }
</style>
